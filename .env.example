# Copy this file to `.env`. Do not commit `.env`.

# Local Python run
DATABASE_URL=mysql+pymysql://roomie_match:roomie_match_password@127.0.0.1:3306/roomie_match?charset=utf8mb4
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=60
GROQ_API_KEY=
APP_DEBUG=false

# Docker Compose defaults
MYSQL_DATABASE=roomie_match
MYSQL_ROOT_PASSWORD=roomie_match_root
MYSQL_USER=roomie_match
MYSQL_PASSWORD=roomie_match_password
MYSQL_PORT=3306
API_PORT=8000

# Tests default to SQLite in-memory when this is omitted.
# TEST_DATABASE_URL=sqlite+pysqlite:///:memory:
